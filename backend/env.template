# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# Укажите тип базы данных: mysql или postgresql
DB_CONNECTION=mysql

# MySQL Configuration (для Beget или другого удаленного сервера)
DB_HOST=niwobubofad.beget.app
DB_PORT=3306
DB_DATABASE=wcb-service
DB_USERNAME=wcb-service
DB_PASSWORD=your_password_here

# PostgreSQL Configuration (альтернатива, если используете PostgreSQL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=billing_db
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# JWT Configuration (ОБЯЗАТЕЛЬНО!)
# Сгенерируйте случайную строку для production
# Можно использовать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# СБИС API (опционально, можно оставить пустым для начала)
