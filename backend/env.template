# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# Укажите параметры подключения к вашей PostgreSQL базе данных
DB_HOST=localhost
DB_PORT=5432
DB_NAME=billing_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration (ОБЯЗАТЕЛЬНО!)
# Сгенерируйте случайную строку для production
# Можно использовать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# СБИС API (опционально, можно оставить пустым для начала)
SBIS_API_URL=https://api.sbis.ru
SBIS_CLIENT_ID=
SBIS_CLIENT_SECRET=
SBIS_ACCESS_TOKEN=

# Email Configuration (опционально)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Telegram Bot (опционально)
TELEGRAM_BOT_TOKEN=

# Firebase (опционально)
FIREBASE_SERVER_KEY=
