# СБИС Подразделение для техотдела (для ротации задач)
# Название или идентификатор подразделения, в котором работают сотрудники техотдела
# Используется для фильтрации сотрудников при ротации задач
# Формат: название подразделения (например: "Техотдел") или ID подразделения
SBIS_DEPARTMENT_NAME=
SBIS_DEPARTMENT_ID=

# СБИС Сотрудники техотдела (для ротации задач)
# Список сотрудников техотдела для автоматической ротации задач при создании
# ВАЖНО: НЕ включайте сюда сотрудника-передатчика (SBIS_MESSENGER_STAFF_ID)!
# Сотрудник-передатчик используется ТОЛЬКО для маршрутизации сообщений, не для выполнения задач.
# Формат 1 (только ФИО, ID будет получен из SBIS): "Иванов Иван Иванович, Петров Петр Петрович"
# Формат 2 (ФИО с ID напрямую, рекомендуется): "Иванов Иван Иванович|123, Петров Петр Петрович|456"
# Чтобы получить список сотрудников с их ID, используйте GET /api/sbis-proxy/tech-staff
# Пример: curl http://localhost:3000/api/sbis-proxy/tech-staff
SBIS_TECH_DEPARTMENT_STAFF=

# СБИС Сотрудник-передатчик (для маршрутизации сообщений)
# ID специального сотрудника в SBIS, который используется как "передатчик" сообщений
# Когда инженер пишет сообщение в задаче SBIS, он выбирает этого сотрудника
# Система определяет, что сообщение от этого сотрудника = сообщение от инженера
# Формат: числовой ID сотрудника в SBIS (например: "123" или "456")
# ВАЖНО: Используйте ID документа (sbis_task_id) для правильной маршрутизации сообщений
SBIS_MESSENGER_STAFF_ID=

