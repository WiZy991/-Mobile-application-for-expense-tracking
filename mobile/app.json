{
	"expo": {
		"name": "WorldCashBox",
		"slug": "worldcashbox",
		"version": "1.0.0",
		"orientation": "portrait",
		"userInterfaceStyle": "light",
		"splash": {
			"resizeMode": "contain",
			"backgroundColor": "#2E7D32"
		},
		"assetBundlePatterns": ["**/*"],
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.worldcashbox.app"
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#2E7D32"
			},
			"package": "com.worldcashbox.app"
		},
		"web": {
		},
		"extra": {
			"apiUrl": "http://localhost:3000/api"
		},
		"plugins": ["expo-notifications"]
	}
}
