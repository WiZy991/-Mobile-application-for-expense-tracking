<?xml version="1.0" encoding="utf-8"?>
<!--
  Wrapper around the raster logo to make it usable as an adaptive icon foreground.
  Android will apply a system mask (circle/squircle/etc) on top of this.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:inset="12dp">

    <bitmap
        android:src="@drawable/ic_launcher_logo"
        android:gravity="center"
        android:filter="true" />

</inset>
