<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/kktModelText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Модель ККТ"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/kktFactoryIdText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Заводской номер:"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/kktRegIdText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Рег. номер:"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/kktOrganizationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Организация:"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/kktSalesPointText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Точка продаж:"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/kktAddressText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Адрес:"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/kktKppText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="КПП:"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/kktStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Статус:"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/kktFirstShiftDateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Первая смена:"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/kktLicenseText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Лицензия:"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_light"
            android:layout_marginVertical="8dp" />

        <TextView
            android:id="@+id/kktFsNumberText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ФН:"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/kktFsFinishDateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Срок ФН до:"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
